{
    "compilerOptions": {
        "module": "commonjs",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "target": "es6",
        "noImplicitAny": false,
        "moduleResolution": "node",
        "outDir": "./dist",
        "sourceMap": true,
        "types": ["jest"]
    },
    "include": ["spec/**/*"],
    "exclude": ["node_modules", "dist"]
}